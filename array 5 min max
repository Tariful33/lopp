#include <stdio.h>

int main()
{
    int arr[5] = {25, 50, 7, 80, 56};
    int n = 5; 
    int max = arr[0];
    int min = arr[0];
    for (int i = 1; i < n; i++) {
        if (arr[i] > max) {
            max = arr[i];
        }
        if (arr[i] < min) {
            min = arr[i];
        }
    }
    printf("Array elements: ");
    for(int i = 0; i < n; i++) printf("%d ", arr[i]);
    printf("\nMaximum element is: %d\n", max);
     printf("Minimum element is: %d\n", min);
    return 0;
}
